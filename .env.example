# Variables para desarrollo local (opcional)
# En produccion en Vercel el frontend usa /api automaticamente
# VITE_API_URL=http://localhost:3001/api

# --- Variables del backend (desarrollo local o dashboard de Vercel) ---
# Cadena de conexion de Neon PostgreSQL
DATABASE_URL=postgresql://usuario:password@host/neondb?sslmode=require

# Credenciales de Gmail para envio de correos (opcional)
# Si no se configuran, los tokens de verificacion se imprimen en consola
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-app-password-de-gmail
